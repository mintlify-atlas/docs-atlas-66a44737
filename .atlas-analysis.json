  "keyFeatures": [
    "String-based filtering with comprehensive comparison operators",
    "Flexible sorting with ascending and descending order",
    "Property aliasing and custom query names",
    "Derived properties and custom operations",
    "Support for nested objects and collections",
    "Arithmetic expressions in filter queries",
    "Property-to-property comparisons",
    "Collection filtering with Any/All semantics",
    "Case-insensitive comparison operators",
    "Entity Framework Core integration",
    "Works with IQueryable and IEnumerable",
    "Custom operator configuration"
  ],
